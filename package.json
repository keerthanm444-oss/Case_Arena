{
  "name": "case-arena",
  "version": "0.1.0",
  "private": true,
  "description": "0 to 100 guide to case competitions \u2014 a fully interactive, hallucination-free learning platform.",
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "npm run lint:citations && next build && npm run pagefind",
    "start": "next start",
    "lint": "next lint",
    "lint:citations": "tsx scripts/verify-citations.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "pagefind": "pagefind --site out --output-subdir _pagefind",
    "tokens:check": "tsx scripts/verify-tokens.ts",
    "prepare": "echo 'skip husky for now'",
    "test:e2e:headed": "playwright test --headed"
  },
